{
  "name": "@lux/templates",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "clean": "rm -rf dist node_modules coverage"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
