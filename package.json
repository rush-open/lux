{
  "name": "@open-rush/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "check": "turbo check",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@open-rush/web",
    "clean": "turbo clean && rm -rf node_modules",
    "db:up": "docker compose -f docker/docker-compose.dev.yml up -d --wait",
    "db:down": "docker compose -f docker/docker-compose.dev.yml down",
    "db:reset": "docker compose -f docker/docker-compose.dev.yml down -v && pnpm db:up && pnpm db:push",
    "db:push": "DATABASE_URL=postgresql://rush:rush@localhost:5432/rush pnpm --filter @open-rush/db db:push",
    "db:generate": "pnpm --filter @open-rush/db db:generate",
    "db:studio": "DATABASE_URL=postgresql://rush:rush@localhost:5432/rush pnpm --filter @open-rush/db db:studio",
    "test:integration": "turbo test:integration",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --fix --no-errors-on-unmatched"
    ],
    "*.{json,css,md}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
